# ─────────────────────────────────────────────
# Option 1 — Local PostgreSQL (default)
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_DATABASE=task_manager
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ─────────────────────────────────────────────
# Option 2 — Amazon RDS (PostgreSQL)
# Steps:
#  1. Go to AWS Console → RDS → Create database
#  2. Choose "PostgreSQL", pick a tier (e.g. db.t3.micro for free tier)
#  3. Set a master username & password
#  4. Under "Connectivity", make sure "Publicly accessible" is Yes
#     (or keep it No and connect via a VPC/bastion host)
#  5. Copy the Endpoint from the RDS instance details page
#  6. Replace the local values above with the ones below
# ─────────────────────────────────────────────
# DB_HOST=your-instance-id.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_USERNAME=your_rds_master_username
# DB_PASSWORD=your_rds_master_password
# DB_DATABASE=task_manager
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false   # set false for RDS default certs

# ─────────────────────────────────────────────
# App / Auth
# ─────────────────────────────────────────────
PORT=3000
JWT_SECRET=change_me_to_a_strong_secret

# Set this to your EC2 public domain / ALB DNS / CloudFront URL in production
# so the backend only accepts requests from your frontend origin.
# Leave blank or omit to allow all origins (fine for local dev).
FRONTEND_URL=http://localhost:5173
